# Copy this file to .env and fill in the values.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=bookmarks
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# WebAuthn / Passkeys
# RP ID must match the domain (no port) the app is served from.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Bookmarks
# Full origin including scheme and port.
WEBAUTHN_ORIGIN=http://localhost:8000
